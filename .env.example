# ── Backend ────────────────────────────────────────────────────────────────
# URL of the FastAPI backend.
# Local dev: leave unset to use the Vite dev proxy (/api → http://localhost:8000)
# Production: set to your Railway deployment URL
# VITE_API_URL=http://localhost:8000

# ── Google AI ──────────────────────────────────────────────────────────────
# Enables the Gemini 2.5 Flash AI pipeline (risk assessment, email generation, bias detection).
# When unset, the backend uses deterministic heuristics as a fallback.
# Obtain from: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your-google-api-key

# ── Clerk Authentication ────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
# Required for production auth. Must start with pk_test_ or pk_live_
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# ── Backend JWT Verification ────────────────────────────────────────────────
# Clerk JWKS URL for server-side JWT verification.
# Format: https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json
# When unset, the backend runs in dev mode and trusts X-User-Id / X-User-Role headers.
# CLERK_JWKS_URL=https://xxxxx.clerk.accounts.dev/.well-known/jwks.json

# ── Manager Access ──────────────────────────────────────────────────────────
# Secret required to claim manager role via /user/setup.
# Defaults to "loanwise-manager-2026" if unset. MUST be changed in production.
# MANAGER_SECRET=change-me-in-production

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for the backend. Defaults to localhost.
# ALLOWED_ORIGINS=https://yourapp.railway.app

# ── Environment ─────────────────────────────────────────────────────────────
# Set to "production" to enforce startup checks (e.g. reject default MANAGER_SECRET).
# ENVIRONMENT=production

# ── Development Shortcuts ───────────────────────────────────────────────────
# Skip Clerk sign-in enforcement for local dev (no sign-in required)
# Set to "true" only in .env.local — never in production
# VITE_DEV_SKIP_AUTH=true

# Use local fixture data instead of hitting the backend
# Useful for UI development when the backend is unavailable
# Set to "true" only in .env.local — never in production
# VITE_USE_MOCK_DATA=true
