# ── Backend ────────────────────────────────────────────────────────────────
# URL of the FastAPI backend.
# Local dev default: http://localhost:8000
# Production: set to your Railway deployment URL
VITE_API_URL=http://localhost:8000

# ── Clerk Authentication ────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
# Required for production auth. Must start with pk_test_ or pk_live_
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# ── Development Shortcuts ───────────────────────────────────────────────────
# Skip Clerk sign-in enforcement for local dev (no sign-in required)
# Set to "true" only in .env.local — never in production
# VITE_DEV_SKIP_AUTH=true

# Use local fixture data instead of hitting the backend
# Useful for UI development when the backend is unavailable
# Set to "true" only in .env.local — never in production
# VITE_USE_MOCK_DATA=true
